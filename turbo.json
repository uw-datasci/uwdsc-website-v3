{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "NODE_ENV",
        "DATABASE_URL",
        "NEXT_PUBLIC_APP_URL",
        "SUPABASE_URL",
        "SUPABASE_PUBLISHABLE_KEY",
        "SUPABASE_SECRET_KEY",
        "GITHUB_TOKEN",
        "FOUNDRY_WORKFLOW_ID",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "RESEND_CAMPAIGN_SEGMENT_ID",
        "RESEND_WEBHOOK_SECRET",
        "DISCORD_INVITE_URL"
      ]
    },
    "lint": { "dependsOn": ["^lint"] },
    "check-types": { "dependsOn": ["^check-types"] },
    "dev": { "cache": false, "persistent": true }
  }
}
